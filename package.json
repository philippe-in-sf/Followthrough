{
  "name": "web-ui-task-manager",
  "version": "1.0.10",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json && rm -rf dist/server/db/migrations && mkdir -p dist/server/db && cp -R server/db/migrations dist/server/db/migrations",
    "start": "NODE_ENV=production node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.test.json",
    "invite:create": "node scripts/run-server-script.mjs server/auth/createInviteCode.ts dist/server/auth/createInviteCode.js",
    "user:create": "node scripts/run-server-script.mjs server/auth/createUser.ts dist/server/auth/createUser.js",
    "version:patch": "npm version patch --no-git-tag-version",
    "deploy": "bash deploy/deploy.sh",
    "deploy:install-systemd": "bash deploy/install-systemd.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
